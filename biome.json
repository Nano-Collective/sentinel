{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"**",
			"!dist",
			"!pnpm-lock.yaml",
			"!coverage",
			"!node_modules",
			"!.husky",
			"!template"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineEnding": "lf",
		"lineWidth": 80
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {}
				}
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "none",
			"style": {
				"noDefaultExport": "off",
				"useBlockStatements": "off",
				"noNonNullAssertion": "warn",
				"noParameterAssign": "off",
				"useConst": "off",
				"useImportType": "off",
				"useTemplate": "off"
			},
			"complexity": {
				"noForEach": "off",
				"useLiteralKeys": "off",
				"useArrowFunction": "off",
				"noBannedTypes": "off"
			},
			"suspicious": {
				"noExplicitAny": "warn",
				"noArrayIndexKey": "off",
				"noConsole": { "level": "off", "options": { "allow": ["log"] } }
			},
			"correctness": {
				"useExhaustiveDependencies": "error",
				"noUnusedVariables": "error",
				"noUnusedImports": "error",
				"noUndeclaredVariables": "off"
			}
		}
	},
	"javascript": {
		"formatter": {
			"semicolons": "always",
			"quoteStyle": "single",
			"jsxQuoteStyle": "double",
			"quoteProperties": "asNeeded",
			"bracketSpacing": false,
			"arrowParentheses": "asNeeded",
			"trailingCommas": "all"
		}
	},
	"json": {
		"formatter": {
			"trailingCommas": "none"
		}
	}
}
